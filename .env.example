# Copy to ".env" in the project root (never commit real secrets).
# Values here are overridden by config/{env}.yaml and by exported ZATRANO_* variables.

ZATRANO_ENV=dev

# HTTP (optional; defaults in config/dev.yaml)
# ZATRANO_HTTP_ADDR=:8080
# ZATRANO_HTTP_CORS_ENABLED=true
# ZATRANO_HTTP_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# ZATRANO_HTTP_RATE_LIMIT_ENABLED=true
# ZATRANO_HTTP_RATE_LIMIT_MAX=200
# ZATRANO_HTTP_RATE_LIMIT_WINDOW=1m
# ZATRANO_HTTP_RATE_LIMIT_REDIS=true
# ZATRANO_HTTP_REQUEST_TIMEOUT=60s
# ZATRANO_HTTP_BODY_LIMIT=4194304

# i18n (optional; requires locales_dir and JSON files — see README)
# ZATRANO_I18N_ENABLED=true
# ZATRANO_I18N_DEFAULT_LOCALE=en
# ZATRANO_I18N_SUPPORTED_LOCALES=en,tr
# ZATRANO_I18N_LOCALES_DIR=locales

# PostgreSQL (GORM / pgx)
# ZATRANO_DATABASE_URL=postgres://user:pass@127.0.0.1:5432/zatrano?sslmode=disable

# Redis (sessions, cache, rate limit — TLS: use rediss://)
# ZATRANO_REDIS_URL=redis://127.0.0.1:6379/0

# JWT (HS256) for /api/v1/private/* — set a long random secret in every environment
# ZATRANO_SECURITY_JWT_SECRET=

# Demo POST /api/v1/auth/token (never enable in prod)
# ZATRANO_SECURITY_DEMO_TOKEN_ENDPOINT=false

# OAuth2 (browser) — requires Redis; set redirect URIs in provider consoles:
#   {base}/auth/oauth/google/callback  and  {base}/auth/oauth/github/callback
# ZATRANO_OAUTH_ENABLED=false
# ZATRANO_OAUTH_BASE_URL=http://127.0.0.1:8080
# ZATRANO_OAUTH_PROVIDERS_GOOGLE_CLIENT_ID=
# ZATRANO_OAUTH_PROVIDERS_GOOGLE_CLIENT_SECRET=
# ZATRANO_OAUTH_PROVIDERS_GITHUB_CLIENT_ID=
# ZATRANO_OAUTH_PROVIDERS_GITHUB_CLIENT_SECRET=

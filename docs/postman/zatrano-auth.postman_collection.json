{
  "info": {
    "name": "Zatrano Auth (Web API/Mobile)",
    "_postman_id": "3b9f34fe-2c41-4d62-8a16-4e5658c738d1",
    "description": "JWT tabanli mobil/API auth endpointleri. Login -> me -> refresh -> logout + hesap yasam dongusu endpointleri.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:3000" },
    { "key": "email", "value": "user@example.com" },
    { "key": "password", "value": "secret123" },
    { "key": "newPassword", "value": "secret1234" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "verifyToken", "value": "" },
    { "key": "resetToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"confirm_password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/register"
      }
    },
    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data) {",
              "  pm.collectionVariables.set('accessToken', json.data.access_token || '');",
              "  pm.collectionVariables.set('refreshToken', json.data.refresh_token || '');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/login"
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/auth/me"
      }
    },
    {
      "name": "Auth - Refresh",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data) {",
              "  pm.collectionVariables.set('accessToken', json.data.access_token || '');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/refresh"
      }
    },
    {
      "name": "Auth - Verify Email",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{verifyToken}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/verify-email"
      }
    },
    {
      "name": "Auth - Resend Verification",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/resend-verification"
      }
    },
    {
      "name": "Auth - Forgot Password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/forgot-password"
      }
    },
    {
      "name": "Auth - Reset Password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"new_password\": \"{{newPassword}}\",\n  \"confirm_password\": \"{{newPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/reset-password"
      }
    },
    {
      "name": "User - Profile",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/user/profile"
      }
    },
    {
      "name": "User - Update Profile",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Demo User Updated\",\n  \"email\": \"{{email}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/user/profile"
      }
    },
    {
      "name": "User - Change Password",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_password\": \"{{password}}\",\n  \"new_password\": \"{{newPassword}}\",\n  \"confirm_password\": \"{{newPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/user/password"
      }
    },
    {
      "name": "Auth - Logout (revoke access + refresh)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/logout"
      }
    }
  ]
}

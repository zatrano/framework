# =============================================================================
# ZATRANO — Fiber v3 Enterprise — Ortam Değişkenleri
# Kopyalama: cp .env.example .env
# Production'da gerçek değerleri ASLA repoya koymayın.
# =============================================================================

# ── Uygulama ──────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_HOST=127.0.0.1
APP_PORT=3000
APP_BASE_URL=http://127.0.0.1:3000
APP_NAME=zatrano
SITE_NAME=ZATRANO

# ── Performans ────────────────────────────────────────────────────────────────
# TEMPLATE_RELOAD=1 — yalnız şablon geliştirirken: her istekte views/*.html yeniden okunur (açık değilse hızlı).
# DEFINITION_CACHE_TTL_SECONDS — definitions sözlüğü bellek önbelleği saniye (0 = her istekte DB; varsayılan 120).

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=zatrano
DB_SSL_MODE=disable          # disable | require | verify-ca | verify-full
DB_TIMEZONE=Europe/Istanbul
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME_MINUTES=60
DB_LOG_LEVEL=info            # silent | error | warn | info

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_RESET=false            # true: başlangıçta tüm anahtarları temizle (DEV ONLY)

# ── Oturum & Çerez ───────────────────────────────────────────────────────────
SESSION_COOKIE_NAME=session_id
SESSION_EXPIRATION_HOURS=0   # 0 = SESSION_TTL_HOURS kullanılır
SESSION_TTL_HOURS=24
SESSION_COOKIE_SAMESITE=lax  # strict | lax | none
COOKIE_DOMAIN=               # production: .yourdomain.com
CSRF_COOKIE_SAMESITE=lax

# ── JWT (REST API) ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-min-32-chars
JWT_ACCESS_TTL_MINUTES=15    # Access token geçerlilik süresi (dakika)
JWT_REFRESH_TTL_DAYS=7       # Refresh token geçerlilik süresi (gün)

# ── CORS (REST API) ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=        # Boş = development'ta herkese açık
                             # Production: https://app.yourdomain.com,https://yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
GLOBAL_RATE_MAX=300          # IP başına dakikada maksimum istek (Redis-backed)
FORM_POST_RATE_MAX=30        # Form POST başına dakikada limit
LOGIN_RATE_MAX=5             # Login denemesi dakikada limit
API_RATE_MAX=120             # API endpoint dakikada limit

# ── Log ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=info               # debug | info | warn | error

# ── Dosya Yükleme ─────────────────────────────────────────────────────────────
# Boş bırakılırsa veya sadece # ile başlayan hatalı değerlerde ./uploads kullanılır
FILE_BASE_PATH=

# ── E-posta (SMTP) ────────────────────────────────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls          # tls | ssl | (boş = plain)
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=ZATRANO

# ── Sentry Error Tracking ─────────────────────────────────────────────────────
SENTRY_DSN=                  # Boş = Sentry devre dışı
SENTRY_TRACES_SAMPLE_RATE=0.1 # 0.0-1.0 arasında trace örnekleme oranı

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/auth/oauth/google/callback

# ── i18n / Dil ────────────────────────────────────────────────────────────────
DEFAULT_LANG=tr              # tr | en (cookie/header yoksa kullanılır)
